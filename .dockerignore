uploads/*.pdf
forms/*.json
data/*.json
data/batch-records

# Detector diagnostic artefacts
data/imgs/*__detected.pdf
data/imgs/eq_section_*.png
data/imgs/equipment_used_section.png
data/imgs/Print*.PNG

# Logs / env
*.log
.env
.env.local

# Tests are not needed in the runtime image
pdf_field_service/tests
